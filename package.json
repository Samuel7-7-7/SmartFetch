{
  "name": "@kevinemt/smartfetch",
  "version": "1.0.0",
  "description": "Un wrapper avanzado, resiliente y altamente configurable sobre la API nativa fetch de JavaScript. Cero dependencias.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "keywords": [
    "fetch",
    "axios",
    "wrapper",
    "http",
    "client"
  ],
  "author": "kevinemt",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  }
}
